{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["code", "message", "data"],
  "properties": {
    "code": {
      "type": "integer",
      "const": 200
    },
    "message": {
      "type": "string",
      "const": "success"
    },
    "data": {
      "type": "object",
      "required": ["id", "username", "role", "status"],
      "properties": {
        "id": {
          "type": ["integer", "number"]
        },
        "username": {
          "type": "string",
          "minLength": 1
        },
        "password": {
          "type": ["null", "string"]
        },
        "phone": {
          "type": ["null", "string"]
        },
        "avatar": {
          "type": ["null", "string"]
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": ["integer", "number"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
